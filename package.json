{
  "name": "soundwave-visualizer",
  "version": "1.0.2",
  "description": "Desktop Soundwave Visualizer & Video Studio",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "package": "node scripts/build.js"
  },
  "keywords": [
    "soundwave",
    "visualizer",
    "music",
    "video",
    "electron",
    "desktop"
  ],
  "author": "Antigravity",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.vkmr007.soundwavestudio",
    "productName": "SoundwaveStudio",
    "win": {
      "target": [
        "portable"
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
